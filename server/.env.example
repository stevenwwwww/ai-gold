PORT=3000
NODE_ENV=development

# LLM 配置
QWEN_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
DEFAULT_MODEL=qwen-plus

# LLM 调用参数
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
SUMMARY_MAX_INPUT_CHARS=30000

# PDF
MAX_PDF_SIZE_MB=10

# 数据库路径（默认 ./data/reports.db）
DB_PATH=

# CORS（多个域名逗号分隔，* 表示所有）
CORS_ORIGIN=*

# Body 大小限制
BODY_LIMIT=15mb
