PORT=3000
NODE_ENV=development

# LLM 配置
QWEN_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx
DEFAULT_MODEL=qwen-plus

# LLM 调用参数
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
SUMMARY_MAX_INPUT_CHARS=30000

# PDF
MAX_PDF_SIZE_MB=10

# 数据库路径（默认 ./data/reports.db）
DB_PATH=

# CORS（多个域名逗号分隔，* 表示所有）
CORS_ORIGIN=*

# Body 大小限制
BODY_LIMIT=15mb

# RAGFlow（知识库 / 检索 / 研报解析）
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY= 'ragflow-RiMjAzZjM4MTllOTExZjFiYTRhY2UwMz'                   # 必填！从 RAGFlow UI 获取
RAGFLOW_DEFAULT_DATASET_ID=         # 可选，默认知识库 ID
RAGFLOW_CHAT_ID=                    # 可选，Chat Assistant ID
RAGFLOW_UI_URL=http://localhost:80
