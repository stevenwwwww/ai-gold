# ============================================================
# 阿里云 ECS 部署 — 需提供的信息
# 复制为 aliyun.env 后填写，执行 ./deploy-to-aliyun.sh 时自动读取
# ============================================================

# ---------- ECS SSH 连接（必填） ----------
# ECS 公网 IP 或弹性 IP（在阿里云控制台-ECS-实例详情查看）
ECS_HOST=8.140.221.86

# SSH 用户名：Ubuntu 常用 ubuntu 或 root；CentOS/Alibaba Linux 常用 root 或 ecs-user
ECS_USER=root

# SSH 认证二选一：
# 1) 密钥路径（推荐）：创建 ECS 时绑定的密钥对，对应私钥在本机的绝对路径
#    如 /Users/xxx/.ssh/aliyun-ecs.pem
ECS_KEY_PATH=

# 2) 密码：若不使用密钥，可填写 ECS 登录密码（需安装 sshpass）
# ECS_PASSWORD=

# ---------- 说明 ----------
# 1. 安全组需放行：22(SSH)、80(HTTP)、443(HTTPS)、8080(RAGFlow 管理)
# 2. 推荐 ECS 规格：4vCPU 16GB，系统盘 40GB+
# 3. 应用配置 RAGFLOW_API_KEY、QWEN_API_KEY 等填写在 deploy/.env.production
