# ============================================================
# 生产环境配置模板 — 复制为 .env.production 后填写实际值
# 部署时 deploy.sh 会读取此文件并应用到各服务
# ============================================================

# ---------- 必填 ----------
# RAGFlow API Key（部署后访问 RAGFlow UI 注册并获取）
RAGFLOW_API_KEY=

# 通义千问 API Key（LLM 对话）
QWEN_API_KEY=

# JWT 密钥（随机字符串，如: openssl rand -hex 32）
JWT_SECRET=

# ---------- 可选（有默认值） ----------
# RAGFlow 地址（同机部署用默认，生产勿改）
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_UI_URL=http://127.0.0.1:80

# 医生助手知识库 ID（首次部署不填，爬虫会自动创建 medical_literature）
RAGFLOW_MEDICAL_DATASET_ID=

# 超管账号（首次登录用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 爬虫邮箱（填写后部署时会自动跑一轮抓取医学文献）
NCBI_EMAIL=
